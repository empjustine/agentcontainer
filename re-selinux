#!/bin/sh
#
# re-selinux — re-label SELinux context for container access
#
# Usage:  ./re-selinux [path]
#
# Flight recorder: silent on success, diagnostics to stderr on failure.
# Runs a throwaway podman rootless container that mounts PATH (default:
# CWD) with :z, so podman handles the SELinux relabeling to
# container_file_t.  No chcon / policycoreutils dependency.
#
# On non-SELinux systems podman silently skips the relabel — safe no-op.

_path="${1:-.}"
_path="$(cd "$_path" 2>/dev/null && pwd)" || {
  >&2 printf 'error: cannot resolve %s\n' "${1:-.}"
  exit 1
}

# Capture stderr; show it only on failure so podman's diagnostics
# are available when something goes wrong (flight recorder pattern).
_err=$(podman run --rm \
  -v "$_path:$_path:z" \
  docker.io/library/busybox:latest \
  sleep 1 2>&1 >/dev/null) || {
  >&2 printf '%s\n' "$_err"
  >&2 printf 'error: podman relabel failed\n'
  exit 1
}
